# STAGING ENVIRONMENT

NODE_ENV=staging
PORT=5001

# MongoDB Atlas Staging Cluster
MONGO_URI=mongodb+srv://<user>:<password>@cluster-staging.mongodb.net/hireapp_staging?retryWrites=true&w=majority

# JWT & Security
JWT_SECRET=staging_jwt_secret_key_in_secrets_manager
JWT_SECRET_REFRESH=staging_jwt_refresh_secret_key_in_secrets_manager

# S3 & CDN
AWS_ACCESS_KEY_ID=staging_access_key
AWS_SECRET_ACCESS_KEY=staging_secret_key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=hireapp-staging-bucket
AWS_CLOUDFRONT_URL=https://staging-cdn.hireapp.com

# Gemini Matchmaking
GEMINI_API_KEY=staging_gemini_api_key

# Stripe (Test Mode)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...

# Sentry
SENTRY_DSN=https://your-staging-dsn@sentry.io/123
