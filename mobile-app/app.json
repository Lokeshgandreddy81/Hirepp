{
  "expo": {
    "name": "HireCircle",
    "slug": "hirecircle",
    "version": "1.0.1",
    "jsEngine": "hermes",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "HireCircle needs camera access to capture your interview and profile videos.",
        "NSMicrophoneUsageDescription": "HireCircle needs microphone access to record audio with your interview videos.",
        "NSUserNotificationUsageDescription": "HireCircle uses notifications for chat messages, application updates, and matches."
      }
    },
    "android": {
      "package": "com.lokesh.hirecircle",
      "versionCode": 2,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": false
    },
    "androidStatusBar": {
      "backgroundColor": "#5b21b6",
      "barStyle": "light-content",
      "translucent": false
    },
    "androidNavigationBar": {
      "backgroundColor": "#ffffff",
      "barStyle": "dark-content"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-localization",
      [
        "expo-camera",
        {
          "cameraPermission": "HireCircle needs camera access to capture your interview and profile videos.",
          "microphonePermission": "HireCircle needs microphone access to record audio with your interview videos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#5b21b6"
        }
      ],
      "expo-document-picker"
    ],
    "extra": {
      "eas": {
        "projectId": "your-project-id"
      }
    }
  }
}
