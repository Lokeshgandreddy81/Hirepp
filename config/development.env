# DEVELOPMENT ENVIRONMENT

NODE_ENV=development
PORT=5001

# MongoDB Local or Atlas Dev Cluster
MONGO_URI=mongodb://localhost:27017/hireapp_dev

# JWT & Security
JWT_SECRET=dev_jwt_secret_key_change_me
JWT_SECRET_REFRESH=dev_jwt_refresh_secret_key_change_me

# S3 & CDN (Localstack or Dev Sandbox)
AWS_ACCESS_KEY_ID=dev_access_key
AWS_SECRET_ACCESS_KEY=dev_secret_key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=hireapp-dev-bucket
AWS_CLOUDFRONT_URL=

# Gemini Matchmaking
GEMINI_API_KEY=dev_gemini_api_key

# Stripe (Test Mode)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...

# Sentry
SENTRY_DSN=
