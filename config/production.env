# PRODUCTION ENVIRONMENT

NODE_ENV=production
PORT=5001

# MongoDB Atlas Production Cluster
MONGO_URI=mongodb+srv://<user>:<password>@cluster-prod.mongodb.net/hireapp_prod?retryWrites=true&w=majority

# JWT & Security (Fetched from Secrets Manager dynamically)
# JWT_SECRET=
# JWT_SECRET_REFRESH=

# S3 & CDN
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=hireapp-prod-bucket
AWS_CLOUDFRONT_URL=https://cdn.hireapp.com

# Gemini Matchmaking
# GEMINI_API_KEY=

# Stripe (Live Mode)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...

# Sentry
# SENTRY_DSN=
